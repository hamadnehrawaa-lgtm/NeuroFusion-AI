@charset "utf-8";

* { box-sizing: border-box; margin: 0px; padding: 0px; }

:root { --black: #030303; --panel: rgba(17,17,17,.86); --panel2: rgba(24,24,24,.92); --gold: #d4af37; --gold2: #f5d76e; --gold3: #8a6f1d; --text: #f7f3e8; --muted: #b9b19d; --border: rgba(212,175,55,.28); --danger: #ff5d5d; --success: #78e08f; --warning: #f6c453; --blue: #7dd3fc; }

html { scroll-behavior: smooth; }

body { font-family: Georgia, "Times New Roman", Inter, system-ui, sans-serif; background: radial-gradient(circle at right top, rgba(212, 175, 55, 0.16), transparent 34%), radial-gradient(circle at left 15%, rgba(138, 111, 29, 0.16), transparent 25%), linear-gradient(rgb(0, 0, 0) 0%, rgb(8, 8, 8) 45%, rgb(0, 0, 0) 100%); color: var(--text); line-height: 1.65; overflow-x: hidden; }

body::before { content: ""; position: fixed; inset: 0px; z-index: -1; pointer-events: none; background-image: linear-gradient(rgba(212, 175, 55, 0.035) 1px, transparent 1px), linear-gradient(90deg, rgba(212, 175, 55, 0.035) 1px, transparent 1px); background-size: 42px 42px; mask-image: linear-gradient(black, transparent 85%); }

a { color: inherit; text-decoration: none; }

.nav { position: sticky; top: 0px; z-index: 30; display: flex; justify-content: space-between; align-items: center; padding: 18px 7%; background: rgba(0, 0, 0, 0.78); backdrop-filter: blur(20px); border-bottom: 1px solid var(--border); }

.logo { display: flex; align-items: center; gap: 12px; font-family: Inter, system-ui, sans-serif; font-weight: 900; letter-spacing: 0.8px; text-transform: uppercase; }

.logo-mark { width: 34px; height: 34px; border-radius: 50%; background: radial-gradient(circle,var(--gold2),var(--gold3)); display: grid; place-items: center; color: rgb(0, 0, 0); box-shadow: rgba(212, 175, 55, 0.55) 0px 0px 35px; font-weight: 900; }

.nav-links { display: flex; gap: 22px; color: var(--muted); font-family: Inter, system-ui, sans-serif; font-size: 13px; text-transform: uppercase; letter-spacing: 0.7px; }

.nav-links a:hover { color: var(--gold2); }

.mobile-menu { display: none; padding: 12px 7%; background: rgba(0, 0, 0, 0.88); border-bottom: 1px solid rgba(212, 175, 55, 0.14); gap: 10px; overflow-x: auto; position: sticky; top: 71px; z-index: 29; font-family: Inter, system-ui, sans-serif; }

.mobile-menu a { white-space: nowrap; color: var(--gold2); border: 1px solid rgba(212, 175, 55, 0.2); border-radius: 999px; padding: 8px 12px; font-size: 12px; background: rgba(212, 175, 55, 0.06); }

.hero { min-height: 94vh; display: grid; grid-template-columns: 1.04fr 0.96fr; gap: 54px; align-items: center; padding: 86px 7% 100px; position: relative; }

.hero::after { content: ""; position: absolute; right: 7%; top: 16%; width: 520px; height: 520px; border: 1px solid rgba(212, 175, 55, 0.12); border-radius: 50%; z-index: -1; }

.kicker { display: inline-flex; align-items: center; gap: 10px; padding: 9px 15px; border: 1px solid var(--border); background: rgba(212, 175, 55, 0.07); color: var(--gold2); border-radius: 999px; font-family: Inter, system-ui, sans-serif; font-size: 13px; font-weight: 800; letter-spacing: 0.6px; text-transform: uppercase; margin-bottom: 24px; }

h1 { font-size: clamp(48px, 7.4vw, 96px); line-height: 0.95; letter-spacing: -3px; margin-bottom: 26px; }

.gold { color: var(--gold2); text-shadow: rgba(212, 175, 55, 0.28) 0px 0px 38px; }

.subtitle { font-size: clamp(18px, 2vw, 23px); color: rgb(223, 214, 191); max-width: 790px; margin-bottom: 24px; font-family: Inter, system-ui, sans-serif; }

.arabic-line { color: var(--muted); font-size: 18px; margin-bottom: 30px; direction: rtl; text-align: left; font-family: "Segoe UI", Tahoma, Arial, sans-serif; }

.hero-actions { display: flex; gap: 14px; flex-wrap: wrap; margin-bottom: 34px; }

.btn { border: 0px; padding: 14px 22px; border-radius: 999px; font-weight: 850; cursor: pointer; transition: 0.25s; font-family: Inter, system-ui, sans-serif; font-size: 14px; letter-spacing: 0.3px; }

.btn-primary { background: linear-gradient(135deg,var(--gold2),var(--gold)); color: rgb(6, 6, 6); box-shadow: rgba(212, 175, 55, 0.21) 0px 18px 44px; }

.btn-primary:hover { transform: translateY(-2px); box-shadow: rgba(212, 175, 55, 0.33) 0px 24px 55px; }

.btn-outline { background: rgba(255, 255, 255, 0.02); color: var(--gold2); border: 1px solid var(--border); }

.btn-outline:hover { border-color: var(--gold2); background: rgba(212, 175, 55, 0.08); }

.research-strip { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; max-width: 790px; }

.research-chip { padding: 14px 16px; border: 1px solid rgba(212, 175, 55, 0.18); background: rgba(17, 17, 17, 0.64); border-radius: 18px; font-family: Inter, system-ui, sans-serif; }

.research-chip strong { display: block; color: var(--gold2); font-size: 18px; margin-bottom: 2px; }

.research-chip span { color: var(--muted); font-size: 12px; text-transform: uppercase; letter-spacing: 0.6px; }

.console { background: linear-gradient(145deg, rgba(15, 15, 15, 0.96), rgba(3, 3, 3, 0.92)); border: 1px solid var(--border); border-radius: 34px; padding: 24px; box-shadow: rgba(0, 0, 0, 0.65) 0px 30px 90px, rgba(212, 175, 55, 0.11) 0px 0px 70px; position: relative; overflow: hidden; }

.console::before { content: ""; position: absolute; inset: -1px; background: linear-gradient(120deg, transparent, rgba(212, 175, 55, 0.12), transparent); transform: translateX(-100%); animation: 5s ease 0s infinite normal none running sheen; }

@keyframes sheen { 
  0% { transform: translateX(-100%); }
  45%, 100% { transform: translateX(100%); }
}

.console-inner { position: relative; }

.console-header { display: flex; justify-content: space-between; align-items: center; padding-bottom: 16px; margin-bottom: 18px; border-bottom: 1px solid rgba(212, 175, 55, 0.18); font-family: Inter, system-ui, sans-serif; }

.status { display: flex; align-items: center; gap: 9px; color: var(--success); font-weight: 750; font-size: 13px; text-transform: uppercase; letter-spacing: 0.6px; }

.dot { width: 10px; height: 10px; background: var(--success); border-radius: 50%; box-shadow: 0 0 18px var(--success); }

.risk-area { display: grid; grid-template-columns: 0.82fr 1.18fr; gap: 18px; margin-bottom: 18px; }

.risk-dial { min-height: 210px; display: grid; place-items: center; border-radius: 28px; background: radial-gradient(circle, rgba(212, 175, 55, 0.18), transparent 60%), rgba(18, 18, 18, 0.88); border: 1px solid rgba(212, 175, 55, 0.18); position: relative; }

.risk-dial::after { content: ""; position: absolute; width: 160px; height: 160px; border-radius: 50%; border-width: 10px; border-style: solid; border-right-color: rgba(212, 175, 55, 0.18); border-bottom-color: rgba(212, 175, 55, 0.18); border-left-color: rgba(212, 175, 55, 0.18); border-image: initial; border-top-color: var(--gold2); animation: 8s linear 0s infinite normal none running rotate; }

@keyframes rotate { 
  100% { transform: rotate(360deg); }
}

.risk-value { z-index: 2; font-size: 58px; font-weight: 950; font-family: Inter, system-ui, sans-serif; color: var(--gold2); }

.risk-value.high { color: var(--danger); }

.risk-label { z-index: 2; color: var(--muted); font-family: Inter, system-ui, sans-serif; font-size: 12px; text-transform: uppercase; letter-spacing: 1px; margin-top: -50px; }

.metrics { display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; }

.metric { background: rgba(27, 27, 27, 0.78); border: 1px solid rgba(212, 175, 55, 0.14); border-radius: 22px; padding: 15px; font-family: Inter, system-ui, sans-serif; }

.metric small { color: var(--muted); display: block; margin-bottom: 5px; font-size: 12px; }

.metric strong { color: var(--text); font-size: 17px; }

.signal-panel { height: 90px; border-radius: 24px; background: linear-gradient(rgba(212, 175, 55, 0.06) 1px, transparent 1px) 0% 0% / 24px 24px, linear-gradient(90deg, rgba(212, 175, 55, 0.06) 1px, transparent 1px), rgba(12, 12, 12, 0.85); border: 1px solid rgba(212, 175, 55, 0.16); overflow: hidden; margin-bottom: 18px; }

svg { width: 100%; height: 100%; }

.wave { fill: none; stroke: var(--gold2); stroke-width: 3; stroke-linejoin: round; stroke-linecap: round; stroke-dasharray: 950; animation: 3.2s linear 0s infinite normal none running dash; filter: drop-shadow(rgba(212, 175, 55, 0.5) 0px 0px 8px); }

@keyframes dash { 
  0% { stroke-dashoffset: 950; }
  100% { stroke-dashoffset: 0; }
}

.ai-alert { padding: 15px; border-radius: 22px; border: 1px solid rgba(120, 224, 143, 0.24); background: rgba(120, 224, 143, 0.08); color: rgb(223, 255, 231); font-family: Inter, system-ui, sans-serif; margin-bottom: 15px; transition: 0.3s; }

.ai-alert.high { border-color: rgba(255, 93, 93, 0.38); background: rgba(255, 93, 93, 0.12); color: rgb(255, 227, 227); }

section { padding: 96px 7%; }

.academic-section { background: linear-gradient(rgba(212, 175, 55, 0.055), rgba(0, 0, 0, 0.06)), rgba(10, 10, 10, 0.65); border-top: 1px solid rgba(212, 175, 55, 0.12); border-bottom: 1px solid rgba(212, 175, 55, 0.12); }

.section-head { max-width: 980px; margin-bottom: 42px; }

.eyebrow { color: var(--gold2); font-family: Inter, system-ui, sans-serif; font-weight: 850; font-size: 13px; letter-spacing: 1.3px; text-transform: uppercase; margin-bottom: 12px; }

